# Rust build output. Bind-mounted into the build containers, so it also serves as the
# cross-`podman run` compilation cache (the role .ccache played for the C++ build).
/target/

# CARGO_HOME inside the container, so the crate registry persists across `podman run`
# invocations instead of re-downloading every build.
/.cargo/

# Fetched ONNX Runtime SDKs (headers + shared libraries), per target.
/sdk/

/dist/

__pycache__/
/.venv/
/.ruff_cache/

# Generated by examples/load_inputs/make_demo.py
/examples/load_inputs/add_two.onnx
/examples/load_inputs/sample.npz
